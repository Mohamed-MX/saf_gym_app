# SAF Gym — Backend Environment Variables
# ─────────────────────────────────────────
# Copy this file to .env and fill in your API keys.
# For cloud deployment, set these as environment variables in your
# hosting dashboard instead (Render → Environment, Railway → Variables).

# ── LLM API Keys ──────────────────────────────────────────────────────────────
# Add the keys you have. Leave empty the ones you don't use.
# The server will try them in order: anthropic → gemini → groq → cerebras → openrouter → mistral

ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=

# ── Dataset Path (local development only) ─────────────────────────────────────
# Only needed when running locally. On the cloud, the dataset file is uploaded
# next to main.py so the server finds it automatically.
DATASET_PATH=d:\Slim and fit\saf_gym_app\Final_model\fitness_dataset_v4.json

# ── Optional Settings ─────────────────────────────────────────────────────────
# Number of similar examples to send to the LLM (default: 3)
TOP_K=3
